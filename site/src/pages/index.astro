---
import Layout from '../layouts/Layout.astro';

const features = [
	{ title: "Memory Core",        body: "Persistent project decisions in .dipralix/memory/ + cross-project patterns. The agent remembers across sessions." },
	{ title: "Lazy Context",       body: "Skills loaded per-request from .dipralix/skills/. Stops wasting tokens on irrelevant boilerplate." },
	{ title: "Peer Review",        body: "Red/Blue team debate on high-risk bash commands. Arbitrator decides. Rejections short-circuit execution." },
	{ title: "Comment Protocol",   body: "Write // DIPRALIX: refactor this in any source file. /tasks list → execute → marks DIPRALIX-DONE: when finished." },
	{ title: "Plan Visualizer",    body: "Terminal ASCII dependency graph with risk badges. Parses .dipralix/plans/current.md." },
	{ title: "Living Docs",        body: "/docs sync regenerates ARCHITECTURE.md against the current codebase, Mermaid diagram included." },
	{ title: "Code Fingerprinting", body: "dipralix --init detects your stack, scaffolds project + safety + approval configs, prints a 0–100 quality score." },
	{ title: "Approval Matrix",    body: "Four-level per-action policy (Auto / Notify / Confirm / Deny) loaded from .dipralix/approval.toml." },
	{ title: "Infra Awareness",    body: "Static analysis for Dockerfile, Kubernetes, Terraform. No cloud API calls, no leaked state." },
	{ title: "Browser Engine",     body: "/fetch <url> — reqwest + HTML→Markdown extractor + on-disk cache. No external API costs." },
];
---

<Layout title="Dipralix — multi-model terminal AI coding agent">
	<!-- Hero ------------------------------------------------------------- -->
	<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
		<div class="absolute inset-0 -z-10">
			<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(99,102,241,0.15),_transparent_50%)]"></div>
			<div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
		</div>

		<div class="container mx-auto px-6 text-center max-w-4xl">
			<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 text-xs font-medium tracking-widest text-white/60 mb-8">
				<span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
				v0.1.0 — Phase 2 features shipped
			</div>

			<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter mb-6 bg-clip-text text-transparent bg-gradient-to-b from-white to-white/40 leading-[1.05]">
				Code with every model.<br />
				<span class="bg-gradient-to-r from-accent-primary to-purple-400 bg-clip-text text-transparent">Pay for none of them.</span>
			</h1>

			<p class="text-xl md:text-2xl text-white/60 max-w-2xl mx-auto mb-10 leading-relaxed">
				A multi-model terminal coding agent. One 12 MB Rust binary. Free with Gemini's 1,500 req/day tier. Bring Claude and GPT keys for the hard parts.
			</p>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-12">
				<a href="#install" class="btn-primary text-base px-8 py-4 w-full sm:w-auto font-medium">
					Install in 30 seconds
				</a>
				<a href="https://github.com/pratikacharya1234/dipralix" class="px-8 py-4 glass rounded-lg font-medium hover:bg-white/5 transition-all w-full sm:w-auto">
					Star on GitHub
				</a>
			</div>

			<div class="max-w-2xl mx-auto">
				<div class="text-xs uppercase tracking-widest text-white/30 mb-3">macOS · Linux</div>
				<div class="font-mono text-sm bg-black/40 border border-white/10 rounded-lg p-4 text-left overflow-x-auto">
					<span class="text-white/40">$ </span><span class="text-white/90">curl -fsSL https://raw.githubusercontent.com/pratikacharya1234/dipralix/main/install.sh | bash</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Why -------------------------------------------------------------- -->
	<section class="py-24 border-t border-white/5">
		<div class="container mx-auto px-6 max-w-5xl">
			<div class="grid md:grid-cols-3 gap-12 text-center">
				<div>
					<div class="text-5xl font-bold tracking-tighter mb-3 bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">$0</div>
					<div class="text-white/60">Forever. No trial. Use Gemini's free tier and code 1,500 requests a day with zero credit card.</div>
				</div>
				<div>
					<div class="text-5xl font-bold tracking-tighter mb-3 bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">12 MB</div>
					<div class="text-white/60">Single static Rust binary. No Node, no Python, no Docker. Runs anywhere from a Raspberry Pi to a Mac Studio.</div>
				</div>
				<div>
					<div class="text-5xl font-bold tracking-tighter mb-3 bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">1M</div>
					<div class="text-white/60">Token context. 5× Claude Code. 15× Copilot. Drop your entire repo into the prompt and ask hard questions.</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Features grid ---------------------------------------------------- -->
	<section class="py-24 border-t border-white/5">
		<div class="container mx-auto px-6 max-w-6xl">
			<div class="text-center mb-16">
				<div class="text-xs uppercase tracking-widest text-accent-primary mb-3">Ten native features</div>
				<h2 class="text-4xl md:text-5xl font-bold tracking-tighter mb-4">No plugins. No MCPs. No subscriptions.</h2>
				<p class="text-white/60 max-w-2xl mx-auto">Other agents glue these together with external services and plugin marketplaces. Dipralix builds every one of them into the Rust core.</p>
			</div>

			<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{features.map((f) => (
					<div class="group p-6 rounded-xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] hover:border-white/10 transition-all">
						<div class="text-base font-semibold mb-2 text-white">{f.title}</div>
						<div class="text-sm text-white/60 leading-relaxed">{f.body}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Install ---------------------------------------------------------- -->
	<section id="install" class="py-24 border-t border-white/5">
		<div class="container mx-auto px-6 max-w-3xl">
			<div class="text-center mb-12">
				<div class="text-xs uppercase tracking-widest text-accent-primary mb-3">Install</div>
				<h2 class="text-4xl md:text-5xl font-bold tracking-tighter mb-4">Pick your OS.</h2>
				<p class="text-white/60">Each command downloads the prebuilt binary for v0.1.0 and puts <code class="text-white/80 font-mono text-sm bg-white/5 px-1.5 py-0.5 rounded">dipralix-cli</code> on your PATH.</p>
			</div>

			<div class="space-y-6">
				<div>
					<div class="text-xs uppercase tracking-widest text-white/40 mb-2">macOS · Linux</div>
					<div class="font-mono text-sm bg-black/40 border border-white/10 rounded-lg p-4 overflow-x-auto">
						<span class="text-white/40">$ </span><span class="text-white/90">curl -fsSL https://raw.githubusercontent.com/pratikacharya1234/dipralix/main/install.sh | bash</span>
					</div>
				</div>
				<div>
					<div class="text-xs uppercase tracking-widest text-white/40 mb-2">Windows (PowerShell)</div>
					<div class="font-mono text-sm bg-black/40 border border-white/10 rounded-lg p-4 overflow-x-auto">
						<span class="text-white/40">PS&gt; </span><span class="text-white/90">irm https://raw.githubusercontent.com/pratikacharya1234/dipralix/main/install.ps1 | iex</span>
					</div>
				</div>
				<div>
					<div class="text-xs uppercase tracking-widest text-white/40 mb-2">Build from source</div>
					<div class="font-mono text-sm bg-black/40 border border-white/10 rounded-lg p-4 overflow-x-auto leading-6">
						<span class="text-white/40">$ </span><span class="text-white/90">git clone https://github.com/pratikacharya1234/dipralix</span><br />
						<span class="text-white/40">$ </span><span class="text-white/90">cd dipralix &amp;&amp; cargo build --release</span>
					</div>
				</div>
			</div>

			<div class="mt-12 p-6 rounded-xl border border-accent-primary/30 bg-accent-primary/5">
				<div class="text-sm font-semibold mb-2">Then get a free Gemini key (30s, no card):</div>
				<a href="https://aistudio.google.com/apikey" class="text-accent-primary hover:underline text-sm break-all">https://aistudio.google.com/apikey</a>
				<div class="mt-4 font-mono text-sm bg-black/40 border border-white/10 rounded-lg p-4 overflow-x-auto leading-6">
					<span class="text-white/40">$ </span><span class="text-white/90">export DIPRALIX_API_KEY="your-free-key"</span><br />
					<span class="text-white/40">$ </span><span class="text-white/90">dipralix-cli</span>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -------------------------------------------------------------- -->
	<section class="py-24 border-t border-white/5">
		<div class="container mx-auto px-6 max-w-2xl text-center">
			<h2 class="text-3xl md:text-4xl font-bold tracking-tighter mb-4">Read the code.</h2>
			<p class="text-white/60 mb-8">All 17 tools, the safety classifier, the agent loop — every line is open source.</p>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-3">
				<a href="https://github.com/pratikacharya1234/dipralix" class="btn-primary text-base px-8 py-4 w-full sm:w-auto font-medium">Open the repo</a>
				<a href="https://github.com/pratikacharya1234/dipralix/blob/main/CHANGELOG.md" class="px-8 py-4 glass rounded-lg font-medium hover:bg-white/5 transition-all w-full sm:w-auto">Read the changelog</a>
			</div>
		</div>
	</section>
</Layout>
