---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Dipralix — the multi-model terminal AI coding agent. Written in Rust. Free."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://avatars.githubusercontent.com; font-src 'self'; connect-src 'self' https://api.github.com;" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<style is:global>
			@font-face {
				font-family: 'Inter';
				src: url('/fonts/Inter-VariableFont_slnt,wght.ttf') format('truetype');
				font-weight: 100 900;
				font-display: swap;
				font-style: normal;
			}
			@font-face {
				font-family: 'JetBrains Mono';
				src: url('/fonts/JetBrainsMono-VariableFont_wght.ttf') format('truetype');
				font-weight: 100 800;
				font-display: swap;
				font-style: normal;
			}
		</style>
	</head>
	<body class="bg-background text-white selection:bg-accent-primary/30">
		<header class="fixed top-0 left-0 right-0 z-50 glass border-b border-white/5">
			<nav class="container mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tighter flex items-center gap-2">
					<span class="w-8 h-8 bg-accent-primary rounded flex items-center justify-center text-sm font-bold">D</span>
					DIPRALIX
				</a>
				<div class="flex items-center gap-4">
					<a href="https://github.com/pratikacharya1234/dipralix" class="text-sm font-medium hover:text-accent-primary transition-colors">GitHub</a>
					<a href="https://github.com/pratikacharya1234/dipralix/releases/latest" class="btn-primary py-2 px-4 text-sm">Download</a>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="py-10 border-t border-white/5 bg-surface">
			<div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-white/40">
				<div>© 2026 Dipralix. MIT licensed. Built in Rust.</div>
				<div class="flex gap-6">
					<a href="https://github.com/pratikacharya1234/dipralix" class="hover:text-white transition-colors">GitHub</a>
					<a href="https://github.com/pratikacharya1234/dipralix/releases/latest" class="hover:text-white transition-colors">Releases</a>
					<a href="https://github.com/pratikacharya1234/dipralix/blob/main/CHANGELOG.md" class="hover:text-white transition-colors">Changelog</a>
				</div>
			</div>
		</footer>
	</body>
</html>
